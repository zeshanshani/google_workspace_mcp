# Environment variables to set in the Railway dashboard.
# Copy the keys (not these example values) into Railway → Variables.

# --- Required ---
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# --- Server binding ---
# main.py checks $PORT first; Railway sets $PORT automatically, so you do
# NOT need to set WORKSPACE_MCP_PORT. Set WORKSPACE_MCP_HOST so the server
# binds to 0.0.0.0 rather than the default.
WORKSPACE_MCP_HOST=0.0.0.0

# --- Stateless OAuth 2.1 (required for multi-user Railway deployment) ---
MCP_ENABLE_OAUTH21=true
WORKSPACE_MCP_STATELESS_MODE=true

# --- External URL ---
# The public Railway URL (https://your-app.up.railway.app). Used to build
# the OAuth callback URL advertised to Google.
WORKSPACE_EXTERNAL_URL=https://your-app.up.railway.app
